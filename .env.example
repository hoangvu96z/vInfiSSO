DATABASE_PORT=3306
DATABASE_USER=jkokiwsihosting_vinfi
DATABASE_PASSWORD=CHANGE_ME
DATABASE_NAME=jkokiwsihosting_vinfi

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Session / JWT ────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_LONG_STRING
